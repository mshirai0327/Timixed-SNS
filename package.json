{
  "name": "drift",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "corepack pnpm --filter @drift/api dev",
    "dev:web": "corepack pnpm --filter @drift/web dev",
    "build": "corepack pnpm -r --if-present build",
    "typecheck": "corepack pnpm -r --if-present typecheck"
  }
}
